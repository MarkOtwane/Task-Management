# ============================================
# TaskFlow Environment Configuration
# ============================================

# Database Configuration
DB_HOST=mysql
DB_PORT=3306
DB_NAME=taskflow
DB_USER=taskflow_user
DB_PASSWORD=taskflow_password
DB_ROOT_PASSWORD=root_password

# Application Configuration
APP_ENV=development
APP_URL=http://localhost
APP_DEBUG=true

# Resend API Configuration (for email)
RESEND_API_KEY=your_resend_api_key_here

# Session Configuration
SESSION_TIMEOUT=3600
SESSION_SECURE=false
SESSION_HTTP_ONLY=true

# Email Configuration
MAIL_FROM=noreply@taskflow.app
MAIL_FROM_NAME=TaskFlow

# File Upload Configuration
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=pdf,doc,docx,txt,xlsx,xls,jpg,jpeg,png,gif

# Security
JWT_SECRET=your_jwt_secret_key_here
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000
